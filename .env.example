# ==========================================================
# TradingInfoTool — Vorlage für Umgebungsvariablen
# ----------------------------------------------------------
# So benutzen:
#   1. Diese Datei kopieren und in ".env" umbenennen
#         Windows (PowerShell):  Copy-Item .env.example .env
#   2. Die Platzhalter unten durch deine echten Werte ersetzen
#   3. Die .env NIEMALS committen (ist bereits in .gitignore)
#
# WICHTIG: Diese .env.example enthält absichtlich NUR Platzhalter.
#          Echte Tokens/Keys gehören ausschliesslich in die .env.
# ==========================================================

# GitHub Personal Access Token
# Erstellen/verwalten: https://github.com/settings/tokens
# Tipp: minimale Rechte (scopes) + Ablaufdatum (expiration) setzen.
GITHUB_TOKEN=dein_github_token_hier

# Claude API Key (Anthropic)
# Erstellen/verwalten: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=dein_anthropic_api_key_hier

# CoinGecko Demo API Key (kostenlos, kein Kreditkarte noetig)
# Erstellen: https://www.coingecko.com/en/api/pricing -> "Create Free Account" ->
#            Developer's Dashboard -> API Key generieren
# Ohne Key: 30 Req/Min (anonym, in der Praxis unzuverlaessig - laengere Sperren moeglich)
# Mit Demo-Key: 100 Req/Min, stabiler. App funktioniert auch ohne Key (Fallback),
# aber ein Key wird empfohlen.
COINGECKO_API_KEY=dein_coingecko_key_hier

# Groq API Key (kostenlos, kein Kreditkarte noetig, kein KYC)
# Erstellen: https://console.groq.com -> Anmeldung per Google/GitHub/E-Mail (<60 Sek.) ->
#            "API Keys" -> "Create API Key"
# Primaere KI-Analyse-Ebene ab Phase 3 (Llama 3.3 70B via Groq LPU-Hardware).
# Kein Kraken-Key noetig (oeffentliche Endpunkte, siehe Basisinfos/Spezifikation.md Kap. 8).
GROQ_API_KEY=dein_groq_key_hier

# FRED API Key (St. Louis Fed, kostenlos, kein Kreditkarte noetig)
# Erstellen: https://fredaccount.stlouisfed.org/apikeys (Key wird sofort vergeben)
# Fed/EZB/M2/CPI/ISM-Ersatz(Philly-Fed)/BoJ/BoK-Leitzinsen fuer Makro-Kontext (R-5.1/-5.2),
# siehe api/macro.py + Basisinfos/Spezifikation.md Kap. 8. Kein Key fuer PBoC noetig
# (Eastmoney-Endpunkt, oeffentlicher Token bereits im Code).
FRED_API_KEY=dein_fred_key_hier

# BGeometrics / bitcoin-data.com API Key (kostenlos, Registrierung z.B. per Google)
# Erstellen: https://portal.bgeometrics.com/signup -> Login/Profile -> API Key
# On-Chain-Metriken (MVRV-Z-Score, NUPL, Realized Price, SOPR) - Free-Tier: 10 Req/Std,
# 15 Req/Tag, daher sparsam abrufen (siehe api/macro.py). Kap. 8/16 der Spezifikation.
BGEOMETRICS_API_KEY=dein_bgeometrics_key_hier

# Bank of Korea ECOS API Key (kostenlos, aber Registrierung mit Identitaetspruefung
# noetig - kann fuer Nicht-Koreaner/ohne koreanische Telefonnummer ein Hindernis sein)
# Erstellen: https://ecos.bok.or.kr/#/ -> Registrierung -> "OPEN API 인증키 신청"
# Key wird laut Doku "meist innerhalb 1 Tag" nutzbar, nicht immer sofort wie bei FRED.
# Korea-M2 (5. Notenbank neben Fed/EZB/BoJ/PBoC) fuer die globale Liquiditaetssicht,
# siehe api/macro.py + Basisinfos/Spezifikation.md Kap. 8.
ECOS_API_KEY=dein_ecos_key_hier

# Bitpanda API Key (nur lesend genutzt - Bestands-/Cash-Reserve-Abgleich, siehe
# importer/bitpanda_sync.py). Erstellen/verwalten: bitpanda.com -> Account -> API Keys.
# Scope "Balance" genuegt; ein Key mit "Trading, Transaction, Balance" funktioniert
# ebenso, da die App ausschliesslich GET-Aufrufe macht (P-7, kein Order-/Auszahlungs-
# zugriff ueber Bitpanda API-Keys ueberhaupt moeglich - alle Scopes sind laut Bitpanda-
# Doku rein lesend). Ohne Key bleibt die manuelle Excel-Import/Export- und Fiat-Cash-
# Eingabe (Portfolio-Tab) voll nutzbar (P-8: Kernfunktion braucht den Key nicht).
BITPANDA_API_KEY=dein_bitpanda_key_hier

# Remote-Steuer-Seite (2026-07-11, siehe remote/server.py + Basisinfos/
# Tailscale-Setup-Anleitung.md + Regelwerksmanual.md Kap. 12/13). Erreichbar nur
# innerhalb des Tailscale-VPN-Netzes, dieser Token ist eine ZWEITE Schutzschicht
# obendrauf. Ohne diesen Wert bleibt die Steuer-Seite komplett deaktiviert - kein
# lauschender Port, kein Risiko (P-8). Erzeugen mit:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
REMOTE_ACCESS_TOKEN=dein_generierten_token_hier
